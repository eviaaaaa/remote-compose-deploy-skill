{
  "deployment": {
    "mode": "artifact"
  },
  "build": {
    "enabled": true,
    "workdir": "C:/path/to/local/repo",
    "command": "npm run build",
    "timeoutSec": 3600,
    "idleTimeoutSec": 300,
    "heartbeatSec": 20,
    "logTailLines": 20
  },
  "artifact": {
    "localPath": "dist/app.zip",
    "remotePath": "/opt/app/dist/app.zip",
    "reuseLatestArtifact": false
  },
  "remote": {
    "host": "192.168.1.100",
    "port": 22,
    "username": "deployer",
    "keyFile": "C:/Users/your-user/.ssh/id_rsa",
    "keyStringEnvVar": "",
    "passwordEnvVar": "REMOTE_DEPLOY_PASSWORD",
    "password": ""
  },
  "repoSync": {
    "workdir": "/opt/app",
    "pullCommand": "git pull --ff-only"
  },
  "compose": {
    "workdir": "/opt/app",
    "action": "rebuild",
    "targetScope": "services",
    "services": [
      "my-service"
    ],
    "commandCandidates": [
      "docker compose",
      "podman compose",
      "docker-compose",
      "podman-compose"
    ]
  },
  "healthCheck": {
    "enabled": false,
    "url": "http://127.0.0.1:8080/health",
    "remoteCommand": "",
    "timeoutSec": 15
  }
}
